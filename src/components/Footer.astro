---
import { localePath, t, type Locale } from "../lib/i18n";
import type { UITranslations } from "../lib/db";

interface Props {
  locale: Locale;
  ui: UITranslations;
}

const { locale, ui } = Astro.props;
const homePath = localePath("/", locale);
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200 mt-12">
  <div class="max-w-screen-xl mx-auto p-6 md:py-8">
    <div class="sm:flex sm:items-center sm:justify-between">
      <a href={homePath} class="flex items-center mb-4 sm:mb-0 space-x-3 rtl:space-x-reverse">
        <svg class="w-7 h-7 text-blue-600" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        <span class="self-center text-xl font-bold whitespace-nowrap text-gray-900">Router<span class="text-blue-600">Hub</span></span>
      </a>
      <span class="block text-sm text-gray-500 sm:text-center">
        &copy; {year} <a href={homePath} class="hover:underline">RouterHub</a>. {t(ui, "footer.rights")}
      </span>
    </div>
  </div>
</footer>
