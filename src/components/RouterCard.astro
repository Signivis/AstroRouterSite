---
import StarRating from "./StarRating.astro";
import type { Router } from "../lib/db";

interface Props {
  router: Router;
}

const { router } = Astro.props;
---

<a href={`/router/${router.slug}`} class="group">
  <div class="max-w-sm bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden h-full flex flex-col">
    <div class="relative overflow-hidden">
      <img
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
        src={router.image_url}
        alt={router.name}
        loading="lazy"
      />
      <span class="absolute top-3 right-3 bg-blue-600 text-white text-xs font-semibold px-2.5 py-1 rounded-sm">
        {router.wifi_standard}
      </span>
    </div>
    <div class="p-5 flex flex-col flex-1">
      <div class="mb-1">
        <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">{router.brand}</span>
      </div>
      <h5 class="mb-2 text-xl font-bold tracking-tight text-gray-900 group-hover:text-blue-600 transition-colors">
        {router.name}
      </h5>
      <div class="mb-3">
        <StarRating rating={router.rating} />
      </div>
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded-sm">{router.speed}</span>
        <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded-sm">{router.frequency_bands}</span>
      </div>
      <div class="mt-auto flex items-center justify-between">
        <span class="text-2xl font-bold text-gray-900">${router.price}</span>
        <span class="inline-flex items-center px-3 py-2 text-sm font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 transition-colors">
          View Details
          <svg class="rtl:rotate-180 w-3.5 h-3.5 ms-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
          </svg>
        </span>
      </div>
    </div>
  </div>
</a>
