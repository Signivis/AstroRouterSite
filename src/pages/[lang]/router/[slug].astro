---
import Layout from "../../../layouts/Layout.astro";
import StarRating from "../../../components/StarRating.astro";
import { getRouterBySlug, getUITranslations } from "../../../lib/db";
import { isValidLocale, t, localePath, DEFAULT_UI, type Locale } from "../../../lib/i18n";

const { lang, slug } = Astro.params;

if (!lang || !isValidLocale(lang) || lang === "en") {
  return Astro.redirect(slug ? `/router/${slug}` : "/");
}

if (!slug) {
  return Astro.redirect(`/${lang}`);
}

const locale = lang as Locale;
const [router, dbUI] = await Promise.all([
  getRouterBySlug(slug, locale),
  getUITranslations(locale),
]);
const ui = { ...DEFAULT_UI, ...dbUI };

if (!router) {
  return Astro.redirect(`/${lang}`);
}

const homePath = localePath("/", locale);
---

<Layout title={router.name} description={router.description.slice(0, 160)} locale={locale} ui={ui}>
  <!-- Breadcrumb -->
  <nav class="bg-white border-b border-gray-200">
    <div class="max-w-screen-xl mx-auto px-4 py-3">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href={homePath} class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600">
            <svg class="w-3 h-3 me-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="m19.707 9.293-2-2-7-7a1 1 0 0 0-1.414 0l-7 7-2 2a1 1 0 0 0 1.414 1.414L2 10.414V18a2 2 0 0 0 2 2h3a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h3a2 2 0 0 0 2-2v-7.586l.293.293a1 1 0 0 0 1.414-1.414Z"/>
            </svg>
            {t(ui, "nav.home")}
          </a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
            </svg>
            <span class="ms-1 text-sm font-medium text-gray-500 md:ms-2">{router.name}</span>
          </div>
        </li>
      </ol>
    </div>
  </nav>

  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Image -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <img class="w-full h-80 lg:h-96 object-cover" src={router.image_url} alt={router.name} />
      </div>

      <!-- Info -->
      <div>
        <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-sm mb-3 inline-block">
          {router.brand}
        </span>
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-3">{router.name}</h1>
        <div class="mb-4">
          <StarRating rating={router.rating} />
        </div>
        <p class="text-gray-600 text-lg leading-relaxed mb-6">{router.description}</p>
        <div class="flex items-baseline gap-4 mb-6">
          <span class="text-4xl font-extrabold text-gray-900">${router.price}</span>
          <span class="bg-green-100 text-green-800 text-sm font-medium px-2.5 py-0.5 rounded-sm">{t(ui, "detail.in_stock")}</span>
        </div>
        <a href={homePath} class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 inline-flex items-center transition-colors">
          <svg class="w-4 h-4 me-2 rtl:rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 10">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5H1m0 0 4 4M1 5l4-4"/>
          </svg>
          {t(ui, "detail.back")}
        </a>
      </div>
    </div>

    <!-- Specifications Table -->
    <div class="mt-10 bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h2 class="text-xl font-bold text-gray-900">{t(ui, "detail.specs")}</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500">
          <tbody>
            <tr class="border-b border-gray-200">
              <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap bg-gray-50 w-1/3">{t(ui, "detail.wifi_standard")}</th>
              <td class="px-6 py-4">{router.wifi_standard}</td>
            </tr>
            <tr class="border-b border-gray-200">
              <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap bg-gray-50">{t(ui, "detail.max_speed")}</th>
              <td class="px-6 py-4">{router.speed}</td>
            </tr>
            <tr class="border-b border-gray-200">
              <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap bg-gray-50">{t(ui, "detail.frequency_bands")}</th>
              <td class="px-6 py-4">{router.frequency_bands}</td>
            </tr>
            <tr class="border-b border-gray-200">
              <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap bg-gray-50">{t(ui, "detail.ports")}</th>
              <td class="px-6 py-4">{router.ports}</td>
            </tr>
            <tr>
              <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap bg-gray-50">{t(ui, "detail.rating")}</th>
              <td class="px-6 py-4">{router.rating} / 5.0</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Features -->
    <div class="mt-8 bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h2 class="text-xl font-bold text-gray-900">{t(ui, "detail.features")}</h2>
      </div>
      <div class="p-6">
        <ul class="space-y-3">
          {router.features.map((feature: string) => (
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-500 me-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-gray-700">{feature}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</Layout>
